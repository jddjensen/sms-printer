TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Instagram Graph API (Business/Creator account linked to a Facebook Page)
# IG_USER_ID is the numeric IG Business account ID (e.g. 17841400000000000)
# IG_ACCESS_TOKEN is a long-lived Page access token with instagram_basic scope
IG_USER_ID=
IG_ACCESS_TOKEN=
IG_POLL_INTERVAL=300
IG_GRAPH_VERSION=v21.0
